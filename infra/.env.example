# Runtime environment for the deployed multiplayer-racer stack.
# The real values are managed centrally: the GitHub secret RUNTIME_ENV on
# cdilga/multiplayer-racer is written to .env on the target at deploy time
# (see cdilga/ppaas README for the secrets model).

# Public base URL players' phones use (join links + QR codes)
PUBLIC_URL=https://jammers.dilger.dev

# Host port on the deploy target
HOST_PORT=8095

# Cloudflare tunnel (credentials-file mode - fully scriptable, no dashboard)
TUNNEL_ID=
TUNNEL_HOSTNAMES=jammers.dilger.dev,multiplayer-racer.dilger.dev
TUNNEL_CREDENTIALS_B64=
